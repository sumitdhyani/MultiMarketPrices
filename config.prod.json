{
    "system":
    {
        "brokers": "127.0.0.1:9092",
        "hearbeatInterval":5, 
        "hearbeatTimeout":30,
        "numMaxBrokers":11,
        "numMinBrokers":1,
        "logLevel":"INFO",
        "registrationsTopic":"registrations",
        "heartbeatsTopic":"heartbeats",
        "statusTopic":"status",
        "syncDataRequestTopic":"pubSub_sync_data_requests",
        "syncDataTopic":"pubSub_sync_data"
    },
    "groups":
    {
        "BinanceMD":
        {
            "in_topic" : "binance_price_subscriptions",
            "logLevel":"DEBUG",
            "restHost":"api.binance.com",
            "restPort": 443,
            "restApiVersion":"/api/v3",
            "wsHost":"stream.binance.com",
            "wsPort":9443,
            "wsPath": "/stream",
            "wsThrottleRatePerSec": 5
        },
        
        "DataDumper": {},

        "BinanceMD_IT":
        {
            "out_topic" : "binance_price_subscriptions"
        },

        "Binance_PT":
        {
            "out_topic" : "binance_price_subscriptions"
        },

        "dummy": {}
    },
    "apps":
    {
        "BinanceMD_1":
        {
            "group":"BinanceMD"
        },

        "DataDumper_1":
        {
            "group":"DataDumper",
            "targetApp" : "BinanceMD_1"
        },

        "BinanceMD_IT_1":
        {
            "group": "BinanceMD_IT"
        },

        "SDPMock_1":
        {
            "group":"dummy"
        },
        
        "Binance_PT_1":
        {
            "group" : "Binance_PT"
        }
    }
}
